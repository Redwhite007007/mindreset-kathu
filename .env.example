# ---------------------------------------------------------------
# MindReset Kathu — environment variables
# ---------------------------------------------------------------
# The app RUNS WITHOUT any of these variables set. In that "local demo"
# mode, progress is saved to IndexedDB on the device only. Filling these
# in switches the app into full Supabase mode with cross-device sync.
#
# Copy this file to `.env.local` and fill in the values.

# --- Supabase (required for cloud sync, optional for local demo) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by Edge Functions and server actions that need to
# bypass RLS (rare). Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push (required for push notifications only) ---
# Generate with: node scripts/generate-vapid-keys.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:youth@crckathu.co.za

# --- App config (optional) ---
# Displayed on sign-in page and in leader dashboards.
NEXT_PUBLIC_APP_NAME="MindReset Kathu"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_COHORT_SLUG=crc-kathu-youth-2026

# Seed script reads this to create a leader account when running
# `npm run db:reset`. Safe to leave blank.
NEXT_SEED_LEADER_EMAIL=
